// Schema cơ sở dữ liệu cho game "KHỞI NGUỒN"
// Dùng SQLite để có thể chạy hoàn toàn trong mạng LAN, không cần internet.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// LƯU Ý: SQLite không hỗ trợ kiểu `enum` trong Prisma, nên các "trạng thái" bên dưới
// được lưu dưới dạng String với giá trị cố định (kiểm tra hợp lệ ở tầng ứng dụng qua zod).
// Các giá trị hợp lệ cho từng trường (chỉ mang tính tham khảo, không được DB ép buộc):
//   GameSession.status   : DRAFT | RUNNING | PAUSED | FINISHED | LEADERBOARD_PUBLISHED | STORY_PUBLISHED
//   Team.status          : PLAYING | WAITING_FOR_CLUE1 | WAITING_FOR_CLUE2 | WAITING_FOR_Q7 | ANSWERING_Q7 | COMPLETED | DISQUALIFIED | ARCHIVED
//   Question.type        : TEXT | SAFE_DIAL
//   Question.validationMode : AUTO | MANUAL
//   Submission.status    : PENDING_REVIEW | CORRECT | INCORRECT | RETRY_ALLOWED

model GameSession {
  id                     String    @id @default(uuid())
  name                   String    @default("KHỞI NGUỒN")
  status                 String    @default("DRAFT")
  showLiveRanking        Boolean   @default(false)
  startedAt              DateTime?
  pausedAt               DateTime?
  endedAt                DateTime?
  leaderboardPublishedAt DateTime?
  storyPublishedAt       DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model Admin {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  displayName  String
  createdAt    DateTime @default(now())
}

model Team {
  id                     String    @id @default(uuid())
  name                   String
  joinCode               String    @unique
  status                 String    @default("PLAYING")
  totalScore             Int       @default(0)
  clue1Delivered         Boolean   @default(false)
  clue1DeliveredAt       DateTime?
  clue1DeliveredBy       String?
  clue2Delivered         Boolean   @default(false)
  clue2DeliveredAt       DateTime?
  clue2DeliveredBy       String?
  question7Unlocked      Boolean   @default(false)
  question7UnlockedAt    DateTime?
  question7UnlockedBy    String?
  sixTasksCompletedAt    DateTime?
  finalQuestionCompletedAt DateTime?
  startedAt              DateTime  @default(now())
  completedAt            DateTime?
  isActive               Boolean   @default(true)
  isDisqualified         Boolean   @default(false)
  manualRankOverride     Int?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  submissions Submission[]
}

model Question {
  id                 String   @id @default(uuid())
  code               String   @unique // ví dụ: TOY, SAFE, FIRE, BODY, KILLER, MASTERMIND, FINAL
  title              String
  description        String
  points             Int
  order              Int
  type               String   @default("TEXT") // TEXT | SAFE_DIAL | MULTIPLE_CHOICE
  validationMode     String   @default("AUTO")
  revealMode         String   @default("IMMEDIATE") // IMMEDIATE: báo đúng/sai ngay | DEFERRED: chỉ tiết lộ khi "Kết thúc vụ án"
  options            String?  // JSON array các lựa chọn, dùng cho type MULTIPLE_CHOICE
  successMessage     String?  // Thông báo tùy chỉnh hiển thị khi trả lời đúng (chỉ áp dụng revealMode = IMMEDIATE)
  isFinalQuestion    Boolean  @default(false)
  isActive           Boolean  @default(true)
  allowRetryDefault  Boolean  @default(true)
  prerequisiteStage  String?  // "CLUE1" | "CLUE2" | "SIX_TASKS" | null
  safeDialConfig     String?  // JSON config cho két sắt: số vòng, số nấc, mã đúng
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  acceptedAnswers AcceptedAnswer[]
  submissions     Submission[]
}

model AcceptedAnswer {
  id               String @id @default(uuid())
  questionId       String
  answer           String
  normalizedAnswer String

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model Submission {
  id            String   @id @default(uuid())
  teamId        String
  questionId    String
  answer        String
  status        String   @default("PENDING_REVIEW")
  awardedPoints Int      @default(0)
  adminNote     String?
  isDraft       Boolean  @default(false)
  submittedAt   DateTime @default(now())
  reviewedAt    DateTime?
  reviewedBy    String?

  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([questionId])
}

model CluePackage {
  id     String @id @default(uuid())
  name   String
  code   String @unique // CLUE1 | CLUE2
  hint   String
}

model StoryChapter {
  id            String  @id @default(uuid())
  title         String
  content       String
  order         Int
  presenterNote String?
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String?
  adminName  String?
  action     String
  entityType String
  entityId   String?
  metadata   String?
  createdAt  DateTime @default(now())
}
